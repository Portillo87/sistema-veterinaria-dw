# ============================================================
# .gitignore — Sistema de Gestión Veterinaria DW
# ============================================================

# --- Dependencias ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# --- Variables de entorno (NUNCA subir al repositorio) ---
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# --- Build / Distribución ---
dist/
dist-ssr/
build/
out/
.output/

# --- Cobertura de pruebas ---
coverage/
*.lcov
.nyc_output/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Cache ---
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.vite/
*.tsbuildinfo

# --- IDEs y Editores ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# --- Sistema Operativo ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# --- Temporales ---
*.tmp
*.temp
*.bak
*.orig

# --- Testing ---
cypress/videos/
cypress/screenshots/
*.snap

# --- Claude Code (configuración local del IDE) ---
.claude/

# --- Archivos de ejemplo que SÍ deben subirse ---
# !.env.example
